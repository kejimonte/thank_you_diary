<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Thank You Diary Mvp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>

    <!-- Bootstrap Navbar -->
    <nav class="navbar navbar-light bg-light">
      <div class="container d-flex justify-content-between">

        <!-- 左側：ロゴ -->
        <%= link_to "Thank You Diary", root_path, class: "navbar-brand" %>

        <!-- 右側：ログイン状態で切り替え -->
        <div>
          <% if user_signed_in? %>
            <%= link_to "感謝一覧", thanks_path, class: "btn btn-outline-primary me-2" %>
            <%= link_to "ログアウト",
                destroy_user_session_path,
                data: { turbo_method: :delete },
                class: "btn btn-outline-danger" %>
          <% else %>
            <%= link_to "新規登録", new_user_registration_path, class: "btn btn-primary me-2" %>
            <%= link_to "ログイン", new_user_session_path, class: "btn btn-outline-primary" %>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Flash -->
    <div class="container mt-3">
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>
    </div>

    <!-- Main -->
    <body>
      <div class="main-content container my-5 py-4">
        <%= yield %>
      </div>
    </body>
    <footer class="text-center mt-5 mb-3 text-muted">
      © 2026 Thank You Diary
    </footer>
  </body>
</html>