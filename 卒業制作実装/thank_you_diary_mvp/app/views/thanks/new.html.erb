<h1>感謝共有</h1>

<div class="card shadow-sm">
  <div class="card-body">

    <% if @thank.errors.any? %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @thank.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @thank, local: true do |f| %>

      <div class="mb-3">
        <%= f.label :content, "感謝内容", class: "form-label" %>
        <%= f.text_area :content,
              class: "form-control",
              rows: 4,
              placeholder: "今日のありがとうを書いてみよう" %>
      </div>

      <%= f.submit "投稿する", class: "btn btn-primary" %>

    <% end %>

  </div>
</div>
