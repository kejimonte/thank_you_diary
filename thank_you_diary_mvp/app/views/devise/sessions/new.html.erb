<div class="text-center mb-4">
  <h2>ログイン</h2>
</div>

<div class="devise-form">
  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

    <div class="mb-3 text-center">
      <%= f.label :email, "メールアドレス", class: "form-label" %>
      <%= f.email_field :email, autofocus: true, class: "form-control" %>
    </div>

    <div class="mb-3 text-center">
      <%= f.label :password, "パスワード", class: "form-label" %>
      <%= f.password_field :password, class: "form-control" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="mb-3 text-center">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me, "ログイン状態を保持する" %>
      </div>
    <% end %>

    <%= f.submit "ログイン", class: "btn btn-primary w-100 mt-3" %>


  <% end %>
</div>

<div class="login-container">
  <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: {turbo: false}, class: "google-btn" do %>
  <%= image_tag "google_logo.svg", class: "google-icon" %>
    Googleでログイン
  <% end %>
</div>
<div class="text-center mt-3">
  <%= render "devise/shared/links" %>
</div>
